# Temporal Cloud credentials for the "Start Cloud" flow.
# Copy this file to .env.cloud (gitignored) and fill in your values. mise loads it
# automatically when MISE_ENV=cloud (see mise.cloud.toml).
#
# gRPC endpoint for your Cloud namespace, e.g. my-ns.a1b2c.tmprl.cloud:7233
TEMPORAL_TARGET=<namespace>.<account>.tmprl.cloud:7233
# Fully qualified namespace, e.g. my-ns.a1b2c
TEMPORAL_NAMESPACE=<namespace>.<account>
# Temporal Cloud API key. Provisioning the namespace creates Nexus endpoints, which a
# Namespace-scoped service account API key CANNOT do (insufficient permission). Use an
# account-level API key from a user or account-scoped service account with the right role.
# Generate one: https://docs.temporal.io/cloud/api-keys#generate-an-api-key
TEMPORAL_API_KEY=<your-temporal-cloud-api-key>
